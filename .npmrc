min-release-age=3
# typescript-eslint (<=8.64) declares a `typescript <6.1.0` peer range that
# conflicts with the TypeScript 7 upgrade. `legacy-peer-deps` lets `npm ci`
# proceed instead of erroring on that unsatisfiable peer. Its downside is that
# npm no longer auto-installs *other* peer deps, so the ones we actually need at
# runtime (@polkadot/util, @polkadot/x-randomvalues — peers of
# @polkadot/wasm-crypto) are declared explicitly as root devDependencies.
# Drop this flag and those explicit deps once typescript-eslint supports TS 7.
legacy-peer-deps=true
