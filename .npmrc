min-release-age=3
# typescript-eslint <=8.64 declares a `typescript <6.1.0` peer range, which
# conflicts with our TypeScript 7 upgrade. Allow install to proceed anyway.
# Note: type-aware ESLint is currently non-functional under TS 7 (see the
# non-blocking lint job in .github/workflows/lint.yml). Drop this override once
# typescript-eslint ships TS 7 support.
legacy-peer-deps=true
