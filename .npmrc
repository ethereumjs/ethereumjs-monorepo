min-release-age=3
# typescript-eslint (<=8.64) declares a `typescript <6.1.0` peer range that
# conflicts with the TypeScript 7 upgrade. The lockfile is generated with
# `npm install --force` so real peer deps (e.g. @polkadot/util) are still
# present; this flag only stops `npm ci` from erroring on the unsatisfiable
# typescript-eslint peer. Drop both once typescript-eslint supports TS 7.
legacy-peer-deps=true
